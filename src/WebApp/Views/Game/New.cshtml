@model IReadOnlyList<Domain.GameConfig>
@{
    ViewData["Title"] = "New Game";
}

<h1>New Game</h1>
<p>Select a configuration to start playing.</p>

@if (Model.Count == 0)
{
    <p>No configurations available. <a asp-controller="Config" asp-action="Create">Create one</a> first.</p>
}
else
{
    <div class="config-list">
        @foreach (var config in Model)
        {
            <div class="config-card">
                <h3>@config.Name</h3>
                <p>@config.Rows x @config.Columns &mdash; Connect @config.WinCondition &mdash; @config.Topology</p>
                <form asp-action="Start" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="configName" value="@config.Name" />
                    <button type="submit" class="btn">Play</button>
                </form>
            </div>
        }
    </div>
}
