@model IReadOnlyList<Application.Game.Dto.GameStateDto>
@{
    ViewData["Title"] = "Load Game";
}

<h1>Load Game</h1>

@if (Model.Count == 0)
{
    <p>No saved games available.</p>
}
else
{
    <table class="config-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Config</th>
                <th>Saved At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var save in Model)
            {
                <tr>
                    <td>@save.Name</td>
                    <td>@save.Config.Name (@save.Config.Rows x @save.Config.Columns)</td>
                    <td>@save.SavedAt.ToString("g")</td>
                    <td>
                        <form asp-action="Resume" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="saveName" value="@save.Name" />
                            <button type="submit" class="btn">Resume</button>
                        </form>
                        <form asp-action="DeleteSave" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="saveName" value="@save.Name" />
                            <button type="submit" class="btn-link" onclick="return confirm('Delete this save?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back</a>
