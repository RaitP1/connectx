@model IReadOnlyList<Domain.GameConfig>
@{
    ViewData["Title"] = "Configurations";
}

<h1>Configurations</h1>

<a asp-action="Create" class="btn">Create New Configuration</a>

@if (Model.Count == 0)
{
    <p>No configurations available. <a asp-action="Create">Create one</a>.</p>
}
else
{
    <table class="config-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Size</th>
                <th>Win</th>
                <th>Topology</th>
                <th>Player 1</th>
                <th>Player 2</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var config in Model)
            {
                <tr>
                    <td>@config.Name</td>
                    <td>@config.Rows x @config.Columns</td>
                    <td>@config.WinCondition</td>
                    <td>@config.Topology</td>
                    <td>@FormatPlayer(config.Player1Name, config.Player1Type)</td>
                    <td>@FormatPlayer(config.Player2Name, config.Player2Type)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@config.Name">Edit</a>
                        <form asp-action="Delete" asp-route-id="@config.Name" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-link" onclick="return confirm('Delete this configuration?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    static string FormatPlayer(string name, Domain.PlayerType type) =>
        type.IsAI ? $"{name} ({type.Difficulty} AI)" : $"{name} (Human)";
}
