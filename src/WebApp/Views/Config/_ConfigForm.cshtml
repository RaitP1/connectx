@model WebApp.Models.ConfigFormModel

<div asp-validation-summary="All" class="validation-summary"></div>

<form asp-action="@ViewData["FormAction"]" asp-route-id="@ViewData["RouteId"]" method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" />
    </div>

    <div class="form-row">
        <div class="form-group">
            <label asp-for="Rows"></label>
            <input asp-for="Rows" type="number" min="1" />
        </div>
        <div class="form-group">
            <label asp-for="Columns"></label>
            <input asp-for="Columns" type="number" min="1" />
        </div>
        <div class="form-group">
            <label asp-for="WinCondition">Win Condition</label>
            <input asp-for="WinCondition" type="number" min="1" />
        </div>
    </div>

    <div class="form-group">
        <label asp-for="Topology"></label>
        <select asp-for="Topology" asp-items="Html.GetEnumSelectList<Domain.EBoardTopology>()"></select>
    </div>

    <fieldset>
        <legend>Player 1</legend>
        <div class="form-row">
            <div class="form-group">
                <label asp-for="Player1Name">Name</label>
                <input asp-for="Player1Name" />
            </div>
            <div class="form-group">
                <label asp-for="Player1Symbol">Symbol</label>
                <input asp-for="Player1Symbol" maxlength="2" />
            </div>
            <div class="form-group">
                <label asp-for="Player1Type">Type</label>
                <select asp-for="Player1Type">
                    <option>Human</option>
                    <option>Easy AI</option>
                    <option>Medium AI</option>
                    <option>Hard AI</option>
                </select>
            </div>
        </div>
    </fieldset>

    <fieldset>
        <legend>Player 2</legend>
        <div class="form-row">
            <div class="form-group">
                <label asp-for="Player2Name">Name</label>
                <input asp-for="Player2Name" />
            </div>
            <div class="form-group">
                <label asp-for="Player2Symbol">Symbol</label>
                <input asp-for="Player2Symbol" maxlength="2" />
            </div>
            <div class="form-group">
                <label asp-for="Player2Type">Type</label>
                <select asp-for="Player2Type">
                    <option>Human</option>
                    <option>Easy AI</option>
                    <option>Medium AI</option>
                    <option>Hard AI</option>
                </select>
            </div>
        </div>
    </fieldset>

    <button type="submit" class="btn">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
