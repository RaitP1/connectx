@page
@model WebApp.Pages.Configs.EditModel
@{
    ViewData["Title"] = "Edit Configuration";
}

<h1>Edit Configuration: @Model.Config.Name</h1>

<form method="post">
    <input type="hidden" asp-for="Config.Name" />
    <div class="form-group">
        <label asp-for="Config.Rows">Rows (3-20)</label>
        <input asp-for="Config.Rows" type="number" min="3" max="20" />
    </div>
    <div class="form-group">
        <label asp-for="Config.Columns">Columns (3-20)</label>
        <input asp-for="Config.Columns" type="number" min="3" max="20" />
    </div>
    <div class="form-group">
        <label asp-for="Config.WinCondition">Win Condition (3-10)</label>
        <input asp-for="Config.WinCondition" type="number" min="3" max="10" />
        <span asp-validation-for="Config.WinCondition" class="validation-message"></span>
    </div>
    <div class="form-group">
        <label asp-for="Config.Topology">Topology</label>
        <select asp-for="Config.Topology">
            <option value="Rectangle">Rectangle</option>
            <option value="Cylinder">Cylinder</option>
        </select>
    </div>
    <div class="form-group">
        <label>
            <input asp-for="Config.Player1IsAI" type="checkbox" /> Player 1 is AI
        </label>
        <select asp-for="Config.Player1Difficulty">
            <option value="Easy">Easy</option>
            <option value="Medium">Medium</option>
            <option value="Hard">Hard</option>
        </select>
    </div>
    <div class="form-group">
        <label>
            <input asp-for="Config.Player2IsAI" type="checkbox" /> Player 2 is AI
        </label>
        <select asp-for="Config.Player2Difficulty">
            <option value="Easy">Easy</option>
            <option value="Medium">Medium</option>
            <option value="Hard">Hard</option>
        </select>
    </div>
    <button type="submit" class="btn btn-success">Save</button>
    <a href="/Configs" class="btn btn-primary">Cancel</a>
</form>
